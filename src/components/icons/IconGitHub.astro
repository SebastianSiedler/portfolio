---
import { siGithub } from 'simple-icons';

interface Props {
  size?: number;
  class?: string;
}
const { size = 16, class: className } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="currentColor"
  class={className}
  aria-hidden="true"
>
  <path d={siGithub.path} />
</svg>
