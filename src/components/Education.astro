---
import { education } from '../data/education';
import type { Lang } from '../i18n';
import { getTranslations } from '../i18n';
import { formatDate } from '../lib/dates';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
---

<section id="education" class="py-16 sm:py-24 bg-gray-50 dark:bg-gray-900/40">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-gray-100 mb-12">
      {t.sections.education}
    </h2>

    <div class="relative">
      <div
        class="absolute left-6 top-2 bottom-2 w-px bg-gray-200 dark:bg-gray-800 hidden sm:block"
      >
      </div>

      <div class="space-y-10">
        {
          education.map((item) => (
            <div class="relative flex gap-6 sm:gap-8">
              <!-- Logo -->
              <div class="relative z-10 flex-shrink-0">
                <div class="flex items-center justify-center w-12 h-12 rounded-full bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 overflow-hidden shadow-sm">
                  <img
                    src={item.logo}
                    alt={item.institution}
                    class="w-full h-full object-contain"
                  />
                </div>
              </div>

              <!-- Content -->
              <div class="flex-1 min-w-0 pb-2">
                <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
                  <div>
                    <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100">
                      {item.studyType} – {item.area}
                    </h3>
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 transition-colors"
                    >
                      {item.institution}
                    </a>
                  </div>
                  <div class="text-right flex-shrink-0">
                    <p class="text-sm text-gray-500 dark:text-gray-500 whitespace-nowrap">
                      {formatDate(item.startDate, lang)} – {formatDate(item.endDate, lang)}
                    </p>
                    <p class="text-xs text-gray-400 dark:text-gray-600">{item.location}</p>
                  </div>
                </div>

                {item.honors && item.honors.length > 0 && (
                  <div class="mt-2 flex flex-wrap gap-1.5">
                    {item.honors.map((honor) => (
                      <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-gray-900 text-white dark:bg-gray-700 dark:text-gray-200">
                        {honor}
                      </span>
                    ))}
                  </div>
                )}

                {item.highlights && item.highlights.length > 0 && (
                  <ul class="mt-3 space-y-1.5">
                    {item.highlights.map((h) => (
                      <li class="text-sm text-gray-600 dark:text-gray-400 flex items-start gap-2">
                        <span class="text-gray-300 dark:text-gray-600 shrink-0">–</span>
                        <span>{h}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
